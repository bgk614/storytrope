# Copy this file to .env.local (used by the app at runtime) and fill in real values.
# See app.module.ts's Joi validationSchema for what's required vs optional.

PORT=4000
BACK_URL=http://localhost:4000
FRONT_URL=http://localhost:3000
DATABASE_URL=postgresql://user:password@localhost:5432/storytrope
JWT_SECRET=change-me
SESSION_DAYS=7
# Number of reverse proxies (nginx/load balancer) in front of the app.
# Set to 1+ in production behind a proxy so rate limiting sees real client IPs.
# Keep 0 when the app is exposed directly (otherwise X-Forwarded-For can be spoofed).
TRUST_PROXY_HOPS=0
