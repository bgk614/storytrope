# netcup 서버에서 docker-compose.yml 옆에 .env로 복사해 사용
#   cp .env.docker.example .env
# DATABASE_URL은 compose가 아래 POSTGRES_* 값으로 조립하므로 직접 쓰지 않는다.

POSTGRES_USER=storytrope
POSTGRES_PASSWORD=change-me
POSTGRES_DB=storytrope

PORT=4000
BACK_URL=https://api.storytrope.com
FRONT_URL=https://storytrope.com
JWT_SECRET=change-me
SESSION_DAYS=7
# 앞단 리버스 프록시(nginx) 1대 기준. 프록시 없이 직접 노출하면 0으로.
TRUST_PROXY_HOPS=1
